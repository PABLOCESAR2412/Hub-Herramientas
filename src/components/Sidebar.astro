---
const currentPath = Astro.url.pathname;
---

<aside class="sidebar">
  <div class="brand">
    <div class="brand-icon">
      <svg viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2z"/></svg>
    </div>
    Hub de Herramientas
  </div>
  
  <div class="nav-section">
    <div class="nav-title">Disponibles</div>
    <a href="/" class={`nav-item ${currentPath === '/' ? 'active' : ''}`}>
      Marca de Agua
    </a>
    <a href="/compressor" class={`nav-item ${currentPath === '/compressor' ? 'active' : ''}`}>
      Comprimir Imagen
    </a>
    <a href="/converter" class={`nav-item ${currentPath === '/converter' ? 'active' : ''}`}>
      Convertir Formato
    </a>
  </div>

  <div class="nav-section">
    <div class="nav-title">Próximamente</div>
    <a href="#" class="nav-item disabled">
      Redimensionar <span class="badge">Pronto</span>
    </a>
  </div>
</aside>

<style>
.sidebar {
  width: 260px;
  background-color: var(--bg-base);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}
.brand {
  padding: 24px;
  display: flex;
  align-items: center;
  gap: 12px;
  font-weight: 600;
  font-size: 16px;
  letter-spacing: -0.2px;
}
.brand-icon {
  width: 26px;
  height: 26px;
  border-radius: 6px;
  background: var(--accent);
  box-shadow: 0 0 16px rgba(108, 92, 231, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}
.brand-icon svg { width: 14px; height: 14px; fill: #fff; }

.nav-section {
  padding: 12px;
  margin-bottom: 8px;
}
.nav-title {
  font-family: var(--font-mono);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--text-tertiary);
  margin-bottom: 12px;
  padding: 0 12px;
}
.nav-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 12px;
  border-radius: 8px;
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 14px;
  margin-bottom: 4px;
  transition: all 0.2s;
}
.nav-item.active {
  background-color: rgba(108, 92, 231, 0.1);
  color: var(--accent);
  font-weight: 500;
}
.nav-item.disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.nav-item:not(.disabled):hover {
  color: var(--text-main);
  background-color: var(--bg-panel);
}
.nav-item.active:hover {
  background-color: rgba(108, 92, 231, 0.15);
}
.badge {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  padding: 3px 6px;
  border-radius: 4px;
  background-color: var(--border);
  color: var(--text-secondary);
  letter-spacing: 0.5px;
}
</style>
