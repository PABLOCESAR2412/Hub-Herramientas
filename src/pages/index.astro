---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';

const tools = [
  { title: 'Marca de Agua', icon: '🎨', path: '/watermark', desc: 'Protege tus imágenes añadiendo tu propio logo o texto como marca de agua.', tag: 'Imágenes' },
  { title: 'Comprimir Imagen', icon: '📦', path: '/compressor', desc: 'Reduce el peso de tus imágenes sin perder calidad visible.', tag: 'Imágenes' },
  { title: 'Convertir Formato', icon: '🔄', path: '/converter', desc: 'Cambia entre PNG, JPEG, WebP, SVG y PDF fácilmente.', tag: 'Imágenes' },
  { title: 'Redimensionar', icon: '📏', path: '/resizer', desc: 'Cambia el tamaño y resolución de tus imágenes.', tag: 'Imágenes' },
  { title: 'Extraer Colores', icon: '🎨', path: '/colors', desc: 'Obtén la paleta de colores predominante de cualquier foto.', tag: 'Imágenes' },
  { title: 'Recortar Imagen', icon: '✂️', path: '/cropper', desc: 'Ajusta y recorta imágenes a proporciones específicas.', tag: 'Imágenes' },
  { title: 'Limpiar Metadatos', icon: '🔒', path: '/exif', desc: 'Elimina datos ocultos de privacidad (GPS, cámara) de las fotos.', tag: 'Imágenes' },
  
  { title: 'Generar Favicons', icon: '✨', path: '/favicon', desc: 'Crea un paquete ZIP de iconos para desarrollo web.', tag: 'Web' },
  { title: 'Acortador de Links', icon: '🔗', path: '/shortener', desc: 'Convierte URLs largas en enlaces fáciles de compartir.', tag: 'Web' },
  
  { title: 'Formateador JSON', icon: '{"}', path: '/json-formatter', desc: 'Embellece y valida código JSON desordenado.', tag: 'Texto' },
  { title: 'Analizador de Texto', icon: '📝', path: '/text-counter', desc: 'Cuenta palabras, caracteres y tiempo de lectura estimado.', tag: 'Texto' },
  
  { title: 'Unir PDFs', icon: '📄', path: '/pdf-merge', desc: 'Combina múltiples archivos PDF en uno solo fácilmente.', tag: 'PDF' },
];
---

<Layout title="Dashboard">
  <Sidebar />
  <main class="main-content">
    <Topbar 
      title="Bienvenido a tu Hub de Herramientas" 
      desc="&mdash; Selecciona una de las utilidades ultrarrápidas y seguras (100% en el navegador)." 
    />
    
    <div class="workspace" style="padding: 32px; overflow-y: auto;">
      <div class="grid-container">
        {tools.map((tool) => (
          <a href={tool.path} class="tool-card">
            <div class="tool-tag">{tool.tag}</div>
            <div class="tool-icon">{tool.icon}</div>
            <h3 class="tool-title">{tool.title}</h3>
            <p class="tool-desc">{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
.grid-container {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 24px;
  max-width: 1400px;
  margin: 0 auto;
}
.tool-card {
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px;
  text-decoration: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  display: flex;
  flex-direction: column;
}
.tool-card:hover {
  transform: translateY(-4px);
  border-color: var(--accent);
  box-shadow: 0 12px 24px rgba(0,0,0,0.15);
}
.tool-tag {
  position: absolute;
  top: 16px;
  right: 16px;
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  background: var(--bg-base);
  color: var(--text-tertiary);
  padding: 4px 8px;
  border-radius: 4px;
  border: 1px solid var(--border);
}
.tool-icon {
  font-size: 32px;
  margin-bottom: 16px;
  width: 56px;
  height: 56px;
  background: var(--bg-base);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--border);
}
.tool-title {
  color: var(--text-main);
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 8px;
}
.tool-desc {
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1.5;
  flex-grow: 1;
}
</style>
