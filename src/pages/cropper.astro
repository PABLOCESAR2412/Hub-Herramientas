---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
import 'cropperjs/dist/cropper.css';
---

<Layout title="Recortar Imagen">
  <Sidebar />
  <main class="main-content">
    <Topbar 
      title="Recortar Imagen" 
      desc="&mdash; Selecciona la porción exacta de tu imagen. Ajuste libre o con proporciones fijas." 
    />
    
    <div class="workspace">
      <div class="workspace-view" id="viewCropper">
        
        <aside class="controls-panel">
          
          <div class="upload-zone" id="dropZoneCrop">
            <div class="upload-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
            </div>
            <div class="upload-text">Click o arrastra tu imagen aquí</div>
            <div class="upload-filename hidden" id="fileNameCrop"></div>
            <input type="file" id="fileInputCrop" accept="image/*" class="hidden">
          </div>

          <div class="control-group">
            <div class="control-header">
              <label class="control-label">Proporción de Recorte</label>
            </div>
            <div class="segmented" style="display: flex; flex-wrap: wrap; gap: 8px;">
              <button class="segment-btn active" data-ratio="NaN" id="ratioFree" style="flex: 1 1 40%;">Libre</button>
              <button class="segment-btn" data-ratio="1" id="ratio11" style="flex: 1 1 40%;">1:1 (Cuadrado)</button>
              <button class="segment-btn" data-ratio="1.7777777777777777" id="ratio169" style="flex: 1 1 40%;">16:9 (Video)</button>
              <button class="segment-btn" data-ratio="1.3333333333333333" id="ratio43" style="flex: 1 1 40%;">4:3</button>
            </div>
          </div>

          <button id="downloadBtnCrop" class="btn-primary" disabled>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            Recortar y Descargar
          </button>

        </aside>

        <section class="preview-area" id="previewAreaCrop">
          <div class="empty-state" id="emptyStateCrop">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
            <div>Sube una imagen para recortarla</div>
          </div>
          <div class="preview-container hidden" id="previewContainerCrop" style="position: relative; background: #0a0a0c; max-height: 100%; display: flex; align-items: center; justify-content: center;">
            <div style="max-width: 100%; max-height: 100%;">
              <img id="previewImgCrop" style="max-width: 100%; display: block;" />
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>

<style>
  .segment-btn {
    padding: 8px;
    font-size: 13px;
  }
</style>

<script>
  import Cropper from 'cropperjs';

  const stateCrop = {
    file: null as File | null,
    cropper: null as Cropper | null
  };

  const dropZoneCrop = document.getElementById('dropZoneCrop');
  const fileInputCrop = document.getElementById('fileInputCrop') as HTMLInputElement;
  const fileNameCrop = document.getElementById('fileNameCrop');
  const emptyStateCrop = document.getElementById('emptyStateCrop');
  const previewContainerCrop = document.getElementById('previewContainerCrop');
  const previewImgCrop = document.getElementById('previewImgCrop') as HTMLImageElement;
  const downloadBtnCrop = document.getElementById('downloadBtnCrop') as HTMLButtonElement;

  const ratioBtns = [
    document.getElementById('ratioFree'),
    document.getElementById('ratio11'),
    document.getElementById('ratio169'),
    document.getElementById('ratio43')
  ];

  if (dropZoneCrop && fileInputCrop) {
    dropZoneCrop.addEventListener('click', () => fileInputCrop.click());
    dropZoneCrop.addEventListener('dragover', (e) => { e.preventDefault(); dropZoneCrop.classList.add('dragover'); });
    dropZoneCrop.addEventListener('dragleave', () => dropZoneCrop.classList.remove('dragover'));
    dropZoneCrop.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZoneCrop.classList.remove('dragover');
      if (e.dataTransfer?.files && e.dataTransfer.files[0]) handleFileCrop(e.dataTransfer.files[0]);
    });
    fileInputCrop.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.files && target.files[0]) handleFileCrop(target.files[0]);
    });
  }

  ratioBtns.forEach(btn => {
    btn?.addEventListener('click', () => {
      if (!stateCrop.cropper) return;
      ratioBtns.forEach(b => b?.classList.remove('active'));
      btn.classList.add('active');
      const ratio = parseFloat(btn.dataset.ratio || 'NaN');
      stateCrop.cropper.setAspectRatio(ratio);
    });
  });

  function handleFileCrop(file: File) {
    if (!file.type.startsWith('image/')) return;
    stateCrop.file = file;
    if(fileNameCrop) {
      fileNameCrop.textContent = file.name;
      fileNameCrop.classList.remove('hidden');
    }
    const uploadText = dropZoneCrop?.querySelector('.upload-text');
    if(uploadText) uploadText.textContent = 'Cambiar imagen cargada';
    
    emptyStateCrop?.classList.add('hidden');
    previewContainerCrop?.classList.remove('hidden');
    if(downloadBtnCrop) downloadBtnCrop.disabled = false;

    const reader = new FileReader();
    reader.onload = (e) => {
      previewImgCrop.src = e.target?.result as string;
      
      if (stateCrop.cropper) {
        stateCrop.cropper.destroy();
      }
      
      // Initialize Cropper
      stateCrop.cropper = new Cropper(previewImgCrop, {
        aspectRatio: NaN,
        viewMode: 1,
        dragMode: 'crop',
        background: false,
        autoCropArea: 0.8,
        responsive: true
      });
      
      // Reset ratio buttons to Free
      ratioBtns.forEach(b => b?.classList.remove('active'));
      ratioBtns[0]?.classList.add('active');
    };
    reader.readAsDataURL(file);
  }

  downloadBtnCrop?.addEventListener('click', () => {
    if (!stateCrop.cropper || !stateCrop.file) return;
    
    // Get cropped canvas
    const canvas = stateCrop.cropper.getCroppedCanvas({
      imageSmoothingEnabled: true,
      imageSmoothingQuality: 'high',
    });
    
    const ext = stateCrop.file.type === 'image/png' ? 'png' : 'jpg';
    const type = stateCrop.file.type === 'image/png' ? 'image/png' : 'image/jpeg';
    
    canvas.toBlob((blob) => {
      if (!blob) return;
      const url = URL.createObjectURL(blob);
      
      const link = document.createElement('a');
      const origParts = stateCrop.file!.name.split('.');
      const origName = origParts.length > 1 ? origParts.slice(0, -1).join('.') : stateCrop.file!.name;
      
      link.download = `${origName}_recortada.${ext}`;
      link.href = url;
      link.click();
      
      // Clean up
      setTimeout(() => URL.revokeObjectURL(url), 1000);
      
      const originalText = downloadBtnCrop.innerHTML;
      downloadBtnCrop.innerHTML = `<span style="color:#48BB78">¡Recortada con éxito!</span>`;
      setTimeout(() => {
        downloadBtnCrop.innerHTML = originalText;
      }, 2000);
      
    }, type, 0.95);
  });
</script>
