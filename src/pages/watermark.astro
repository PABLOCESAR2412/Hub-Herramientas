---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
---

<Layout title="Marca de Agua">
  <Sidebar />
  <main class="main-content">
    <Topbar 
      title="Marca de Agua" 
      desc="&mdash; Protege tus imágenes aplicando texto personalizado directo en tu navegador." 
    />
    
    <div class="workspace">
      <div class="workspace-view">
        <aside class="controls-panel">
          <div class="upload-zone" id="dropZoneWm">
            <div class="upload-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
            </div>
            <div class="upload-text">Click o arrastra tu imagen aquí</div>
            <div class="upload-filename hidden" id="fileNameWm"></div>
            <input type="file" id="fileInputWm" accept="image/*" class="hidden">
          </div>

          <div class="control-group">
            <div class="control-header">
              <label class="control-label">Texto</label>
            </div>
            <input type="text" id="wmText" value="CONFIDENCIAL">
          </div>

          <div class="control-group">
            <div class="control-header">
              <label class="control-label">Tipografía</label>
            </div>
            <select id="wmFont">
              <option value="Inter, sans-serif">Sans (Inter)</option>
              <option value="Georgia, serif">Serif (Georgia)</option>
              <option value="'JetBrains Mono', monospace">Mono (JetBrains)</option>
              <option value="'Courier New', monospace">Mono Alt (Courier)</option>
              <option value="Impact, sans-serif">Fuerte (Impact)</option>
            </select>
          </div>

          <div class="control-group">
            <div class="control-header">
              <label class="control-label">Estilo</label>
            </div>
            <div class="segmented">
              <button class="segment-btn active" data-style="solid" id="styleSolid">Sólido</button>
              <button class="segment-btn" data-style="outline" id="styleOutline">Contorno</button>
            </div>
          </div>

          <div class="control-group">
            <div class="control-header">
              <label class="control-label">Color</label>
            </div>
            <div class="color-picker-wrapper">
              <input type="color" id="wmColor" value="#ffffff">
              <div class="color-hex" id="colorHex">#FFFFFF</div>
            </div>
          </div>

          <div class="control-group">
            <div class="control-header">
              <label class="control-label">Tamaño</label>
              <span class="control-val" id="sizeVal">48px</span>
            </div>
            <input type="range" id="wmSize" min="12" max="140" value="48">
          </div>

          <div class="control-group">
            <div class="control-header">
              <label class="control-label">Opacidad</label>
              <span class="control-val" id="opacityVal">50%</span>
            </div>
            <input type="range" id="wmOpacity" min="5" max="100" value="50">
          </div>

          <div class="control-group">
            <div class="control-header">
              <label class="control-label">Rotación</label>
              <span class="control-val" id="rotateVal">-30°</span>
            </div>
            <input type="range" id="wmRotate" min="-45" max="45" value="-30">
          </div>

          <div class="control-group">
            <div class="control-header">
              <label class="control-label">Modo de Aplicación</label>
            </div>
            <div class="segmented" style="margin-bottom: 16px;">
              <button class="segment-btn" data-mode="position" id="modePos">Posición</button>
              <button class="segment-btn active" data-mode="pattern" id="modePat">Patrón</button>
            </div>
            
            <div id="positionControls" class="hidden">
              <div class="grid-9">
                <div class="grid-pt" data-pos="top-left"></div>
                <div class="grid-pt" data-pos="top-center"></div>
                <div class="grid-pt" data-pos="top-right"></div>
                <div class="grid-pt" data-pos="middle-left"></div>
                <div class="grid-pt active" data-pos="middle-center"></div>
                <div class="grid-pt" data-pos="middle-right"></div>
                <div class="grid-pt" data-pos="bottom-left"></div>
                <div class="grid-pt" data-pos="bottom-center"></div>
                <div class="grid-pt" data-pos="bottom-right"></div>
              </div>
            </div>

            <div id="patternControls">
              <div class="control-header">
                <label class="control-label">Espaciado</label>
                <span class="control-val" id="spacingVal">100px</span>
              </div>
              <input type="range" id="wmSpacing" min="10" max="300" value="100">
            </div>
          </div>

          <button id="downloadBtnWm" class="btn-primary" disabled>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            Descargar PNG
          </button>
        </aside>

        <section class="preview-area" id="previewAreaWm">
          <div class="empty-state" id="emptyStateWm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
            <div>Sube una imagen para previsualizar</div>
          </div>
          <div class="preview-container hidden" id="previewContainerWm">
            <canvas id="canvasWm"></canvas>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>

<style>
/* 9-point grid for specific tool */
.grid-9 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6px;
  width: 140px;
  margin: 16px auto;
}
.grid-pt {
  aspect-ratio: 1;
  background: var(--bg-base);
  border: 1px solid var(--border);
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.2s;
}
.grid-pt:hover { border-color: var(--text-tertiary); }
.grid-pt.active {
  background: var(--accent);
  border-color: var(--accent);
  box-shadow: 0 0 12px rgba(108, 92, 231, 0.25);
}
</style>

<script>
  // Script is scoped to this component in Astro
  const stateWm = {
    image: null,
    text: 'CONFIDENCIAL',
    font: 'Inter, sans-serif',
    style: 'solid',
    color: '#ffffff',
    size: 48,
    opacity: 0.5,
    rotate: -30,
    mode: 'pattern',
    position: 'middle-center',
    spacing: 100
  };

  const dropZoneWm = document.getElementById('dropZoneWm');
  const fileInputWm = document.getElementById('fileInputWm');
  const fileNameWm = document.getElementById('fileNameWm');
  const emptyStateWm = document.getElementById('emptyStateWm');
  const previewContainerWm = document.getElementById('previewContainerWm');
  const canvasWm = document.getElementById('canvasWm') as HTMLCanvasElement;
  const ctxWm = canvasWm?.getContext('2d');
  const downloadBtnWm = document.getElementById('downloadBtnWm') as HTMLButtonElement;

  const wmText = document.getElementById('wmText') as HTMLInputElement;
  const wmFont = document.getElementById('wmFont') as HTMLSelectElement;
  const styleSolid = document.getElementById('styleSolid');
  const styleOutline = document.getElementById('styleOutline');
  const wmColor = document.getElementById('wmColor') as HTMLInputElement;
  const colorHex = document.getElementById('colorHex');
  const wmSize = document.getElementById('wmSize') as HTMLInputElement;
  const sizeVal = document.getElementById('sizeVal');
  const wmOpacity = document.getElementById('wmOpacity') as HTMLInputElement;
  const opacityVal = document.getElementById('opacityVal');
  const wmRotate = document.getElementById('wmRotate') as HTMLInputElement;
  const rotateVal = document.getElementById('rotateVal');
  
  const modePos = document.getElementById('modePos');
  const modePat = document.getElementById('modePat');
  const positionControls = document.getElementById('positionControls');
  const patternControls = document.getElementById('patternControls');
  const wmSpacing = document.getElementById('wmSpacing') as HTMLInputElement;
  const spacingVal = document.getElementById('spacingVal');
  const gridPts = document.querySelectorAll('.grid-pt');

  // Initialize listeners if elements exist
  if (dropZoneWm && fileInputWm) {
    dropZoneWm.addEventListener('click', () => fileInputWm.click());
    dropZoneWm.addEventListener('dragover', (e) => { e.preventDefault(); dropZoneWm.classList.add('dragover'); });
    dropZoneWm.addEventListener('dragleave', () => dropZoneWm.classList.remove('dragover'));
    dropZoneWm.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZoneWm.classList.remove('dragover');
      if (e.dataTransfer?.files && e.dataTransfer.files[0]) handleFileWm(e.dataTransfer.files[0]);
    });
    fileInputWm.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.files && target.files[0]) handleFileWm(target.files[0]);
    });
  }

  wmText?.addEventListener('input', (e) => { stateWm.text = (e.target as HTMLInputElement).value; renderWm(); });
  wmFont?.addEventListener('change', (e) => { stateWm.font = (e.target as HTMLSelectElement).value; renderWm(); });
  
  styleSolid?.addEventListener('click', () => { 
    stateWm.style = 'solid'; 
    styleSolid.classList.add('active'); styleOutline?.classList.remove('active'); 
    renderWm(); 
  });
  styleOutline?.addEventListener('click', () => { 
    stateWm.style = 'outline'; 
    styleOutline.classList.add('active'); styleSolid?.classList.remove('active'); 
    renderWm(); 
  });

  wmColor?.addEventListener('input', (e) => { 
    const val = (e.target as HTMLInputElement).value;
    stateWm.color = val; 
    if(colorHex) colorHex.textContent = val.toUpperCase(); 
    renderWm(); 
  });

  wmSize?.addEventListener('input', (e) => { stateWm.size = parseInt((e.target as HTMLInputElement).value); if(sizeVal) sizeVal.textContent = stateWm.size + 'px'; renderWm(); });
  wmOpacity?.addEventListener('input', (e) => { stateWm.opacity = parseInt((e.target as HTMLInputElement).value)/100; if(opacityVal) opacityVal.textContent = (e.target as HTMLInputElement).value + '%'; renderWm(); });
  wmRotate?.addEventListener('input', (e) => { stateWm.rotate = parseInt((e.target as HTMLInputElement).value); if(rotateVal) rotateVal.textContent = stateWm.rotate + '°'; renderWm(); });

  modePos?.addEventListener('click', () => {
    stateWm.mode = 'position';
    modePos.classList.add('active'); modePat?.classList.remove('active');
    positionControls?.classList.remove('hidden'); patternControls?.classList.add('hidden');
    renderWm();
  });
  modePat?.addEventListener('click', () => {
    stateWm.mode = 'pattern';
    modePat.classList.add('active'); modePos?.classList.remove('active');
    patternControls?.classList.remove('hidden'); positionControls?.classList.add('hidden');
    renderWm();
  });

  wmSpacing?.addEventListener('input', (e) => { stateWm.spacing = parseInt((e.target as HTMLInputElement).value); if(spacingVal) spacingVal.textContent = stateWm.spacing + 'px'; renderWm(); });

  gridPts?.forEach(pt => {
    pt.addEventListener('click', () => {
      gridPts.forEach(p => p.classList.remove('active'));
      pt.classList.add('active');
      stateWm.position = (pt as HTMLElement).dataset.pos || 'middle-center';
      renderWm();
    });
  });

  downloadBtnWm?.addEventListener('click', () => {
    if (!stateWm.image || !canvasWm) return;
    const link = document.createElement('a');
    link.download = 'watermarked_image.png';
    link.href = canvasWm.toDataURL('image/png');
    link.click();
  });

  function handleFileWm(file: File) {
    if (!file.type.startsWith('image/')) return;
    if(fileNameWm) {
      fileNameWm.textContent = file.name;
      fileNameWm.classList.remove('hidden');
    }
    const uploadText = dropZoneWm?.querySelector('.upload-text');
    if(uploadText) uploadText.textContent = 'Cambiar imagen cargada';
    
    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        stateWm.image = img as any;
        emptyStateWm?.classList.add('hidden');
        previewContainerWm?.classList.remove('hidden');
        if(downloadBtnWm) downloadBtnWm.disabled = false;
        renderWm();
      };
      img.src = e.target?.result as string;
    };
    reader.readAsDataURL(file);
  }

  function renderWm() {
    if (!stateWm.image || !canvasWm || !ctxWm) return;
    
    canvasWm.width = stateWm.image.width;
    canvasWm.height = stateWm.image.height;
    ctxWm.drawImage(stateWm.image, 0, 0);

    if (!stateWm.text) return;
    
    ctxWm.globalAlpha = stateWm.opacity;
    ctxWm.font = `${stateWm.size}px ${stateWm.font}`;
    
    const hex = stateWm.color.replace('#', '');
    const r = parseInt(hex.substring(0,2), 16);
    const g = parseInt(hex.substring(2,4), 16);
    const b = parseInt(hex.substring(4,6), 16);
    
    if (stateWm.mode === 'position') {
      const padding = stateWm.size; 
      let x = 0, y = 0;
      
      if (stateWm.position.includes('left')) { x = padding; ctxWm.textAlign = 'left'; }
      else if (stateWm.position.includes('right')) { x = canvasWm.width - padding; ctxWm.textAlign = 'right'; }
      else { x = canvasWm.width / 2; ctxWm.textAlign = 'center'; }
      
      if (stateWm.position.includes('top')) { y = padding; ctxWm.textBaseline = 'top'; }
      else if (stateWm.position.includes('bottom')) { y = canvasWm.height - padding; ctxWm.textBaseline = 'bottom'; }
      else { y = canvasWm.height / 2; ctxWm.textBaseline = 'middle'; }
      
      ctxWm.save();
      ctxWm.translate(x, y);
      ctxWm.rotate(stateWm.rotate * Math.PI / 180);
      if (stateWm.style === 'solid') {
        ctxWm.fillStyle = `rgb(${r},${g},${b})`;
        ctxWm.fillText(stateWm.text, 0, 0);
      } else {
        ctxWm.strokeStyle = `rgb(${r},${g},${b})`;
        ctxWm.lineWidth = Math.max(1, stateWm.size * 0.03);
        ctxWm.strokeText(stateWm.text, 0, 0);
      }
      ctxWm.restore();

    } else if (stateWm.mode === 'pattern') {
      ctxWm.textAlign = 'center';
      ctxWm.textBaseline = 'middle';
      const textMetrics = ctxWm.measureText(stateWm.text);
      const w = textMetrics.width;
      
      const stepX = w + stateWm.spacing;
      const stepY = stateWm.size + stateWm.spacing;
      
      ctxWm.save();
      ctxWm.translate(canvasWm.width / 2, canvasWm.height / 2);
      ctxWm.rotate(stateWm.rotate * Math.PI / 180);
      
      const diag = Math.sqrt(canvasWm.width*canvasWm.width + canvasWm.height*canvasWm.height);
      const startX = -diag; const endX = diag;
      const startY = -diag; const endY = diag;
      
      if (stateWm.style === 'solid') {
        ctxWm.fillStyle = `rgb(${r},${g},${b})`;
      } else {
        ctxWm.strokeStyle = `rgb(${r},${g},${b})`;
        ctxWm.lineWidth = Math.max(1, stateWm.size * 0.03);
      }

      let row = 0;
      for (let y = startY; y < endY; y += stepY) {
        const offsetX = (row % 2 === 1) ? stepX / 2 : 0;
        for (let x = startX; x < endX; x += stepX) {
          if (stateWm.style === 'solid') {
            ctxWm.fillText(stateWm.text, x + offsetX, y);
          } else {
            ctxWm.strokeText(stateWm.text, x + offsetX, y);
          }
        }
        row++;
      }
      ctxWm.restore();
    }
    ctxWm.globalAlpha = 1.0;
  }
</script>
