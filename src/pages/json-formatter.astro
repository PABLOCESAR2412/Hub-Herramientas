---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
---

<Layout title="Formateador JSON">
  <Sidebar />
  <main class="main-content">
    <Topbar 
      title="Formateador JSON" 
      desc="&mdash; Formatea, embellece y valida estructuras JSON desordenadas." 
    />
    
    <div class="workspace" style="display: flex; gap: 24px; padding: 24px; height: calc(100vh - 70px);">
      
      <!-- Input Panel -->
      <div style="flex: 1; display: flex; flex-direction: column; background: var(--bg-panel); border: 1px solid var(--border); border-radius: 12px; overflow: hidden;">
        <div style="padding: 12px 16px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: var(--bg-base);">
          <span style="font-weight: 600; font-size: 14px;">Entrada JSON</span>
          <button id="btnClear" class="btn-primary" style="padding: 6px 12px; font-size: 12px; background: transparent; color: var(--text-secondary); border: 1px solid var(--border);">Limpiar</button>
        </div>
        <textarea id="jsonInput" placeholder="Pega tu JSON aquí..." style="flex: 1; width: 100%; border: none; background: transparent; color: var(--text-main); font-family: var(--font-mono); font-size: 14px; padding: 16px; resize: none; outline: none;"></textarea>
      </div>

      <!-- Controls -->
      <div style="display: flex; flex-direction: column; justify-content: center; gap: 12px;">
        <button id="btnFormat" class="btn-primary" style="width: 120px;" title="Formatear">
          Formatear <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:8px;"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </button>
        <button id="btnMinify" class="btn-primary" style="width: 120px; background: var(--bg-panel); border: 1px solid var(--border); color: var(--text-main);" title="Minificar">
          Minificar <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:8px;"><polyline points="4 14 10 14 10 20"></polyline><polyline points="20 10 14 10 14 4"></polyline><line x1="14" y1="10" x2="21" y2="3"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>
        </button>
      </div>

      <!-- Output Panel -->
      <div style="flex: 1; display: flex; flex-direction: column; background: var(--bg-panel); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; position: relative;">
        <div style="padding: 12px 16px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: var(--bg-base);">
          <span style="font-weight: 600; font-size: 14px;">Resultado</span>
          <button id="btnCopy" class="btn-primary" style="padding: 6px 12px; font-size: 12px;">Copiar Todo</button>
        </div>
        <textarea id="jsonOutput" readonly placeholder="El resultado aparecerá aquí..." style="flex: 1; width: 100%; border: none; background: transparent; color: var(--accent); font-family: var(--font-mono); font-size: 14px; padding: 16px; resize: none; outline: none;"></textarea>
        
        <div id="errorMsg" class="hidden" style="position: absolute; bottom: 16px; left: 16px; right: 16px; background: #F56565; color: white; padding: 12px; border-radius: 8px; font-size: 13px; font-family: var(--font-mono);"></div>
      </div>

    </div>
  </main>
</Layout>

<script>
  const jsonInput = document.getElementById('jsonInput') as HTMLTextAreaElement;
  const jsonOutput = document.getElementById('jsonOutput') as HTMLTextAreaElement;
  const btnFormat = document.getElementById('btnFormat') as HTMLButtonElement;
  const btnMinify = document.getElementById('btnMinify') as HTMLButtonElement;
  const btnClear = document.getElementById('btnClear') as HTMLButtonElement;
  const btnCopy = document.getElementById('btnCopy') as HTMLButtonElement;
  const errorMsg = document.getElementById('errorMsg');

  function processJson(minify = false) {
    if (!errorMsg) return;
    const input = jsonInput?.value.trim();
    if (!input) {
      if(jsonOutput) jsonOutput.value = '';
      return;
    }

    try {
      const parsed = JSON.parse(input);
      const output = minify ? JSON.stringify(parsed) : JSON.stringify(parsed, null, 2);
      if(jsonOutput) jsonOutput.value = output;
      errorMsg.classList.add('hidden');
    } catch (e: any) {
      errorMsg.textContent = `Error JSON: ${e.message}`;
      errorMsg.classList.remove('hidden');
      if(jsonOutput) jsonOutput.value = '';
    }
  }

  btnFormat?.addEventListener('click', () => processJson(false));
  btnMinify?.addEventListener('click', () => processJson(true));
  
  btnClear?.addEventListener('click', () => {
    if(jsonInput) jsonInput.value = '';
    if(jsonOutput) jsonOutput.value = '';
    errorMsg?.classList.add('hidden');
  });

  btnCopy?.addEventListener('click', () => {
    if (jsonOutput?.value) {
      navigator.clipboard.writeText(jsonOutput.value);
      const orig = btnCopy.textContent;
      btnCopy.textContent = '¡Copiado!';
      btnCopy.style.background = '#48BB78';
      btnCopy.style.borderColor = '#48BB78';
      setTimeout(() => {
        btnCopy.textContent = orig;
        btnCopy.style.background = 'var(--accent)';
        btnCopy.style.borderColor = 'var(--accent)';
      }, 1500);
    }
  });
</script>
